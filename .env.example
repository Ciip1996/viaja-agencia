# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Hotelbeds / Bedsonline API
HOTELBEDS_API_KEY=your-api-key
HOTELBEDS_SECRET=your-secret
HOTELBEDS_BASE_URL=https://api.test.hotelbeds.com/hotel-api/1.0
USE_LIVE_HOTELBEDS=true

# Juniper / Naturleon API
JUNIPER_API_KEY=your-api-key
JUNIPER_SECRET=your-secret
JUNIPER_BASE_URL=https://api-edocs.ejuniper.com
USE_LIVE_JUNIPER=false

# General
NEXT_PUBLIC_SITE_URL=http://localhost:3000
